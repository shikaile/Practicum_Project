<!doctype html>
<html lang="en">

<head>
	<!-- Required meta tags -->
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

	<!-- Roboto Font-->
	<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700" type="text/css">

	<!-- Playfair Display - used for the site title -->
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&display=swap">

	<!-- Fancybox Gallery CSS -->
	<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.css">

	<!-- Material design icon-->
	<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

	<link rel="stylesheet" href="https://code.getmdl.io/1.3.0/material.indigo-pink.min.css">

	<script src="https://code.getmdl.io/1.3.0/material.min.js"></script>

	<link rel="stylesheet" href="/css/frame.css">

	<title>DS_Practicum</title>
</head>

<body class="<%= currentPath === '/about' ? 'about-hero' : '' %>">
	<!-- Always shows a header, even in smaller screens. -->
	<div class="mdl-layout--fixed-header mdl-js-layout">
		<header class="mdl-layout__header mdl-layout__header--waterfall">
			<div class="mdl-layout__header-row header-row-title">
				<!-- Title -->
				<a href="/" class="mdl-layout-title">DS_Practicum</a>
				<!-- Auth -->
				<div class="auth-nav">
					<% if (typeof user !== 'undefined' && user) { %>
						<span class="auth-email"><%= user.email %></span>
						<form action="/logout" method="POST" class="auth-logout-form">
							<button type="submit" class="auth-btn">Log Out</button>
						</form>
					<% } else { %>
						<a href="/login" class="auth-btn">Log In</a>
					<% } %>
				</div>
			</div>
			<div class="mdl-layout__header-row">
				<!-- Navigation -->
				<nav>
					<% navLinks.forEach(link => { %>
						<a href="<%= link.path %>" class="<%= currentPath === link.path ? 'active' : '' %>">
							<%= link.label %>
						</a>
					<% }) %>
				</nav>
			</div>
		</header>
	</div>
