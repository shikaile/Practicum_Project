<%- include("../partials/header.ejs") %>

<div class="about-hero-bg">
<div class="contact-page">
  <div class="page-stack">
    <div class="contact-card">
      <h1>About</h1>
      <p class="contact-subhead">DS_Practicum is a data science project.</p>

      <p class="about-body">
        DS_Practicum is a work in progress
      </p>
    </div>

    <div class="contact-box-compact">
      <h2>Contact</h2>

      <form id="contact-form" class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="contact-name">Name</label>
            <input id="contact-name" name="name" type="text" class="feedback-input" placeholder="Jane Doe" />
          </div>
          <div class="form-group">
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" class="feedback-input" placeholder="jane@example.com" />
          </div>
          <div class="form-group">
            <label for="contact-date">Preferred Date</label>
            <input id="contact-date" name="date" type="date" class="feedback-input" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="contact-text">Comment</label>
            <textarea id="contact-text" name="text" class="feedback-input" placeholder="Tell me a bit about what you're looking for..."></textarea>
          </div>
        </div>

        <button type="submit" class="contact-submit">Send Message</button>
      </form>
    </div>
  </div>
</div>
</div>

<%- include("../partials/js.ejs") %>
</body>
</html>
