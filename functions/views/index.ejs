<%- include("partials/header.ejs") %>

<!-- Ported from a contributor's standalone views/home.html. Styling matches
     the dashboard/analytics pages' CourtVision look; auth-gating was
     migrated from client-side sessionStorage to this app's own
     res.locals.user (see controllers/pages/index.js). -->
<style>
    .home-page {
        max-width: 1050px;
        margin: 0 auto;
        padding: 40px 24px;
    }
    .home-hero {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        padding: 40px;
        margin-bottom: 25px;
    }
    .home-hero h1 {
        margin: 0 0 12px;
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
    }
    .home-hero p {
        margin: 0;
        color: var(--cv-text-muted);
        line-height: 1.6;
    }
    .home-hero .home-cta {
        margin-top: 20px;
        display: flex;
        gap: 12px;
    }
    .home-widget-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 25px;
    }
    .home-card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        padding: 25px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .home-card h3 {
        margin: 0 0 8px;
        font-size: 18px;
        color: #ffffff;
        font-weight: 700;
    }
    .home-card p {
        margin: 0 0 20px;
        color: var(--cv-text-muted);
        font-size: 13px;
        line-height: 1.5;
    }
    .home-card .launch-btn {
        color: var(--cv-accent);
        font-weight: 700;
        text-decoration: none;
        font-size: 14px;
    }
    .home-card .launch-btn:hover {
        color: var(--cv-accent-hover);
    }
    .home-quickstart {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        padding: 25px;
    }
    .home-quickstart h3 {
        margin: 0 0 10px;
        color: var(--cv-accent);
        font-size: 16px;
    }
    .home-quickstart ol {
        color: var(--cv-text-muted);
        font-size: 13px;
        line-height: 1.8;
        margin: 0;
        padding-left: 20px;
    }
    @media (max-width: 800px) {
        .home-widget-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="home-page">
    <% if (typeof user !== 'undefined' && user) { %>
        <div class="home-hero">
            <h1>Welcome to CourtVision, <span style="color: var(--cv-accent);"><%= user.email %></span></h1>
            <p>Your unified basketball analytics control station. Log box score stats, monitor roster efficiency (eFG%), track game pace, and turn raw stat sheets into tactical insight.</p>
        </div>

        <div class="home-widget-grid">
            <div class="home-card">
                <div>
                    <h3>Data Ingestion Desk</h3>
                    <p>Upload a game box score CSV or manually enter player performance records to recalculate rolling team performance vectors.</p>
                </div>
                <a href="/dashboard" class="launch-btn">Open Dashboard &rarr;</a>
            </div>
            <div class="home-card">
                <div>
                    <h3>Game Center</h3>
                    <p>Isolate single-match performance matrices, view production chart breakdowns, and study individual match efficiency ratings.</p>
                </div>
                <a href="/game-analytics" class="launch-btn">Launch Game Analytics &rarr;</a>
            </div>
            <div class="home-card">
                <div>
                    <h3>Player Profiles</h3>
                    <p>Conduct a deep evaluation of roster components over time and study scoring, assist, and rebound trends.</p>
                </div>
                <a href="/player-analytics" class="launch-btn">Explore Deep Dives &rarr;</a>
            </div>
        </div>

        <div class="home-quickstart">
            <h3>Quick-Start</h3>
            <ol>
                <li>Head to the <strong>Dashboard</strong> to log a box score CSV or a manual entry.</li>
                <li>Open <strong>Game Analytics</strong> or <strong>Team Analytics</strong> to see instantly populated charts and pace data.</li>
                <li>Use <strong>Player Deep Dive</strong> to track an individual player's trend over the season.</li>
            </ol>
        </div>
    <% } else { %>
        <div class="home-hero">
            <h1>Welcome to <span style="color: var(--cv-accent);">CourtVision</span></h1>
            <p>A unified basketball analytics control station for coaches. Log box score stats, monitor roster efficiency, track game pace, and turn raw stat sheets into tactical insight.</p>
            <div class="home-cta">
                <a href="/signup" class="auth-btn">Sign Up</a>
                <a href="/login" class="auth-btn">Log In</a>
            </div>
        </div>
    <% } %>
</div>

<div id="welcome-modal" class="modal-overlay">
  <div class="modal-box">
    <button type="button" class="modal-close" data-modal-close aria-label="Close">&times;</button>
    <h2>Welcome to CourtVision</h2>
    <p>CourtVision is a basketball analytics tool for coaches to log box scores and track team and player performance over a season.</p>

    <div class="modal-subscribe modal-subscribe-only">
      <p class="modal-subscribe-label">Recieve Periodic Updates</p>

      <form id="modal-subscribe-form" action="/subscribe" method="POST" class="subscribe-form">
        <input name="email" type="email" placeholder="you@example.com" required />
        <button type="submit" class="modal-btn-tertiary">Subscribe</button>
      </form>

      <p class="subscribe-success" data-modal-subscribe-success hidden>Thanks! We'll keep you posted.</p>
      <p class="subscribe-error" data-modal-subscribe-error hidden></p>
    </div>
  </div>
</div>

<%- include("partials/js.ejs") %>
</body>
</html>
