<%- include("../partials/header.ejs") %>

<!-- Ported from a contributor's standalone views/pages/game_analytics.html.
     Styling matches the dashboard's CourtVision look; the data layer was
     migrated from client-side Firestore to this app's own /api/games and
     /api/games/box-scores endpoints (backed by PostgreSQL - see
     public/js/game_analytics.js). Box scores carry a real gameId foreign
     key here, so filtering by game is a plain equality check - no need for
     the contributor's original timestamp-proximity matching hack. -->
<style>
    .game-analytics-page {
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #f0f2f5;
        padding: 30px;
        min-height: 100vh;
        box-sizing: border-box;
    }
    .game-analytics-page .container {
        max-width: 1050px;
        margin: 0 auto;
    }
    .game-analytics-page .control-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .game-analytics-page .control-row h1 {
        margin: 0 0 4px;
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
    }
    .game-analytics-page .control-row p {
        margin: 0;
        color: var(--cv-text-muted);
        font-size: 13px;
    }
    .game-analytics-page select {
        background: var(--cv-bg);
        border: 1px solid var(--cv-border);
        padding: 10px 16px;
        border-radius: 6px;
        color: white;
        font-size: 14px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
    }
    .game-analytics-page .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .game-analytics-page .stat-card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 20px 25px;
    }
    .game-analytics-page .stat-title {
        color: var(--cv-accent);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        margin-bottom: 8px;
    }
    .game-analytics-page .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #ffffff;
    }
    .game-analytics-page .card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        margin-bottom: 25px;
    }
    .game-analytics-page .card h3 {
        margin-top: 0;
        font-size: 18px;
        color: #ffffff;
        font-weight: 700;
        margin-bottom: 12px;
    }
    .game-analytics-page .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .game-analytics-page .placeholder-text {
        text-align: center;
        padding-top: 80px;
        color: var(--cv-text-muted);
    }
    .game-analytics-page .table-scroll-container {
        overflow-x: auto;
    }
    .game-analytics-page table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 14px;
    }
    .game-analytics-page th {
        border-bottom: 2px solid var(--cv-accent);
        color: var(--cv-accent);
        padding: 12px 6px;
        font-weight: 700;
    }
    .game-analytics-page td {
        padding: 12px 6px;
        border-bottom: 1px solid var(--cv-border);
    }
</style>

<div class="game-analytics-page">
    <div class="container">
        <%- include("../partials/analytics-nav.ejs") %>

        <div class="control-row">
            <div>
                <h1>Game Analytics</h1>
                <p>Isolate box score metrics per logged game.</p>
            </div>
            <div>
                <select id="game-selector-dropdown">
                    <option value="">Loading games...</option>
                </select>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">Possession Pace</div>
                <div class="stat-value" id="pace-stat-box">--</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">Offensive Rating</div>
                <div class="stat-value" id="ortg-stat-box">--</div>
            </div>
        </div>

        <div class="chart-grid">
            <div class="card" style="margin-bottom:0;">
                <h3>Single Game Production Distribution</h3>
                <div style="height: 220px; position: relative;" id="container-scoringChart">
                    <p class="placeholder-text">Select a game to generate this chart.</p>
                    <canvas id="scoringDistributionChart" style="display:none;"></canvas>
                </div>
            </div>
            <div class="card" style="margin-bottom:0;">
                <h3>Shooting Performance Matrix (eFG%)</h3>
                <div style="height: 220px; position: relative;" id="container-efficiencyChart">
                    <p class="placeholder-text">Select a game to generate this chart.</p>
                    <canvas id="efficiencyLineChart" style="display:none;"></canvas>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 25px;"></div>

        <div class="card">
            <h3>Match Performance Log Table</h3>
            <div class="table-scroll-container">
                <table>
                    <thead>
                        <tr>
                            <th>Player Name</th>
                            <th style="text-align: center;">MIN</th>
                            <th style="text-align: center;">PTS</th>
                            <th style="text-align: center;">AST</th>
                            <th style="text-align: center;">REB</th>
                            <th style="text-align: center;">STL</th>
                            <th style="text-align: center;">BLK</th>
                            <th style="text-align: center;">TO</th>
                            <th style="text-align: right;">eFG%</th>
                        </tr>
                    </thead>
                    <tbody id="game-matrix-tbody">
                        <tr>
                            <td colspan="9" style="text-align: center; padding: 20px; color: var(--cv-text-muted); font-style: italic;">No games logged yet. Upload a game on the Dashboard first.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/game_analytics.js"></script>

<%- include("../partials/js.ejs") %>
</body>
</html>
