<%- include("../partials/header.ejs") %>

<!-- Ported from a contributor's standalone views/pages/player_analytics.html.
     Styling matches the dashboard's CourtVision look; the data layer was
     migrated from client-side Firestore to this app's own
     /api/games/box-scores endpoint (backed by PostgreSQL - see
     public/js/player_analytics.js). -->
<style>
    .player-analytics-page {
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #f0f2f5;
        padding: 30px;
        min-height: 100vh;
        box-sizing: border-box;
    }
    .player-analytics-page .container {
        max-width: 1050px;
        margin: 0 auto;
    }
    .player-analytics-page .control-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .player-analytics-page .control-row h1 {
        margin: 0 0 4px;
        font-size: 26px;
        font-weight: 800;
        color: #ffffff;
    }
    .player-analytics-page .control-row p {
        margin: 0;
        color: var(--cv-text-muted);
        font-size: 13px;
    }
    .player-analytics-page select {
        background: var(--cv-bg);
        border: 1px solid var(--cv-border);
        padding: 10px 16px;
        border-radius: 6px;
        color: white;
        font-size: 14px;
        font-weight: 600;
        outline: none;
        cursor: pointer;
    }
    .player-analytics-page .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .player-analytics-page .stat-card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 20px 25px;
    }
    .player-analytics-page .stat-title {
        color: var(--cv-accent);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        margin-bottom: 8px;
    }
    .player-analytics-page .stat-value {
        font-size: 1.6rem;
        font-weight: 800;
        color: #ffffff;
    }
    .player-analytics-page .card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        margin-bottom: 25px;
    }
    .player-analytics-page .card h3 {
        margin-top: 0;
        font-size: 18px;
        color: #ffffff;
        font-weight: 700;
        margin-bottom: 12px;
    }
    .player-analytics-page .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .player-analytics-page .placeholder-text {
        text-align: center;
        padding-top: 80px;
        color: var(--cv-text-muted);
    }
    .player-analytics-page .table-scroll-container {
        overflow-x: auto;
    }
    .player-analytics-page table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 14px;
    }
    .player-analytics-page th {
        border-bottom: 2px solid var(--cv-accent);
        color: var(--cv-accent);
        padding: 12px 6px;
        font-weight: 700;
    }
    .player-analytics-page td {
        padding: 12px 6px;
        border-bottom: 1px solid var(--cv-border);
    }
</style>

<div class="player-analytics-page">
    <div class="container">
        <%- include("../partials/analytics-nav.ejs") %>

        <div class="control-row">
            <div>
                <h1>Player Deep Dive</h1>
                <p>Analyze log histories per roster player.</p>
            </div>
            <div>
                <select id="player-profile-selector">
                    <option value="">Loading roster...</option>
                </select>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card"><div class="stat-title">Season Volume</div><div class="stat-value" id="stat-season-ppg">-- PPG</div></div>
            <div class="stat-card"><div class="stat-title">Facilitation Index</div><div class="stat-value" id="stat-season-apg">-- APG</div></div>
            <div class="stat-card"><div class="stat-title">Paint Impact</div><div class="stat-value" id="stat-season-rpg">-- RPG</div></div>
        </div>

        <div class="chart-grid">
            <div class="card" style="margin-bottom:0;">
                <h3>Scoring Trend Log Over Time</h3>
                <div style="height: 200px; position: relative;" id="container-trendChart">
                    <p class="placeholder-text">Select a player to render metrics.</p>
                    <canvas id="playerPointsTrendChart" style="display:none;"></canvas>
                </div>
            </div>
            <div class="card" style="margin-bottom:0;">
                <h3>Secondary Resource Matrix</h3>
                <div style="height: 200px; position: relative;" id="container-resourceChart">
                    <p class="placeholder-text">Select a player to render metrics.</p>
                    <canvas id="playerResourceMatrixChart" style="display:none;"></canvas>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 25px;"></div>

        <div class="card">
            <h3>Historical Game Breakdown</h3>
            <div class="table-scroll-container">
                <table>
                    <thead>
                        <tr>
                            <th>Match Log Reference</th>
                            <th style="text-align: center;">MIN</th>
                            <th style="text-align: center;">PTS</th>
                            <th style="text-align: center;">AST</th>
                            <th style="text-align: center;">REB</th>
                            <th style="text-align: center;">STL</th>
                            <th style="text-align: center;">BLK</th>
                            <th style="text-align: right;">eFG%</th>
                        </tr>
                    </thead>
                    <tbody id="player-history-tbody">
                        <tr>
                            <td colspan="8" style="text-align: center; padding: 20px; color: var(--cv-text-muted); font-style: italic;">No box scores logged yet. Upload a game on the Dashboard first.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/player_analytics.js"></script>

<%- include("../partials/js.ejs") %>
</body>
</html>
