<%- include("../partials/header.ejs") %>

<!-- Ported from a contributor's standalone views/pages/team_analytics.html.
     Styling matches the dashboard's CourtVision look; the data layer was
     migrated from client-side Firestore to this app's own /api/games/box-scores
     endpoint (backed by PostgreSQL - see public/js/team_analytics.js). -->
<style>
    .team-analytics-page {
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #f0f2f5;
        padding: 30px;
        min-height: 100vh;
        box-sizing: border-box;
    }
    .team-analytics-page .container {
        max-width: 1050px;
        margin: 0 auto;
    }
    .team-analytics-page .page-header {
        margin-bottom: 25px;
    }
    .team-analytics-page .page-header h1 {
        color: #ffffff;
        margin: 0 0 4px;
        font-size: 26px;
        font-weight: 800;
    }
    .team-analytics-page .page-header p {
        color: var(--cv-text-muted);
        margin: 0;
        font-size: 13px;
    }
    .team-analytics-page .card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        margin-bottom: 25px;
    }
    .team-analytics-page .card h3 {
        margin-top: 0;
        font-size: 18px;
        color: #ffffff;
        font-weight: 700;
        margin-bottom: 12px;
    }
    .team-analytics-page .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .team-analytics-page .stat-card {
        background-color: var(--cv-card-bg);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 20px 25px;
    }
    .team-analytics-page .stat-title {
        color: var(--cv-accent);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        margin-bottom: 8px;
    }
    .team-analytics-page .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #ffffff;
    }
    .team-analytics-page .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 25px;
    }
    .team-analytics-page .placeholder-text {
        text-align: center;
        padding-top: 80px;
        color: var(--cv-text-muted);
    }
    .team-analytics-page .table-scroll-container {
        overflow-x: auto;
    }
    .team-analytics-page table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 14px;
    }
    .team-analytics-page th {
        border-bottom: 2px solid var(--cv-accent);
        color: var(--cv-accent);
        padding: 12px 6px;
        font-weight: 700;
    }
    .team-analytics-page td {
        padding: 12px 6px;
        border-bottom: 1px solid var(--cv-border);
    }
</style>

<div class="team-analytics-page">
    <div class="container">
        <%- include("../partials/analytics-nav.ejs") %>

        <div class="page-header">
            <h1>Team Analytics</h1>
            <p>Seasonal cumulative box score roster - leaderboard and efficiency breakdown across every logged game.</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">Roster Size</div>
                <div class="stat-value" id="stat-roster-size">--</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">Cumulative Team PTS</div>
                <div class="stat-value" id="stat-team-pts">--</div>
            </div>
        </div>

        <div class="chart-grid">
            <div class="card" style="margin-bottom:0;">
                <h3>Cumulative Points Contribution Leaderboard</h3>
                <div style="height: 240px; position: relative;" id="container-pointsChart">
                    <p class="placeholder-text">Log a game to generate this chart.</p>
                    <canvas id="pointsLeaderboardChart" style="display:none;"></canvas>
                </div>
            </div>
            <div class="card" style="margin-bottom:0;">
                <h3>Roster Efficiency Breakdown (eFG%)</h3>
                <div style="height: 240px; position: relative;" id="container-efficiencyChart">
                    <p class="placeholder-text">Log a game to generate this chart.</p>
                    <canvas id="efficiencyBreakdownChart" style="display:none;"></canvas>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 25px;"></div>

        <div class="card">
            <h3>Seasonal Cumulative Box Score Roster</h3>
            <div class="table-scroll-container">
                <table>
                    <thead>
                        <tr>
                            <th>Player Name</th>
                            <th style="text-align: center;">GP</th>
                            <th style="text-align: center;">Total MIN</th>
                            <th style="text-align: center;">Total PTS</th>
                            <th style="text-align: center;">Total AST</th>
                            <th style="text-align: center;">Total REB</th>
                            <th style="text-align: right;">eFG%</th>
                        </tr>
                    </thead>
                    <tbody id="team-roster-tbody">
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 20px; color: var(--cv-text-muted); font-style: italic;">No box scores logged yet. Upload a game on the Dashboard first.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/team_analytics.js"></script>

<%- include("../partials/js.ejs") %>
</body>
</html>
