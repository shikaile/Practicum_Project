# Copy this to .env for local development (never commit the real .env -
# it's already gitignored). See models/database.js for how these are used.

# --- Local dev ---
# Any reachable Postgres instance (e.g. a local `brew services start postgresql`,
# or Docker). Ignored if INSTANCE_CONNECTION_NAME is set below.
DATABASE_URL=postgres://user:password@localhost:5432/ds_practicum
# Set to "true" only if your Postgres provider requires SSL (most hosted
# providers do; local Postgres usually doesn't).
DATABASE_SSL=true

# --- Cloud SQL (used instead of DATABASE_URL when deployed as a Firebase
# Cloud Function) ---
# Format: "project:region:instance-id" - find it in the Cloud SQL console or
# via `gcloud sql instances describe INSTANCE_ID`.
#INSTANCE_CONNECTION_NAME=hs-basketball-team-stats:us-east4:practicum-fdc
# DB_USER=basketball_app
# DB_PASSWORD=
# DB_NAME=basketball_app_essentials
# DB_IP_TYPE=PUBLIC

# NOTE: firebase.json excludes .env from both Hosting and Functions deploys,
# so this file is local-only. For the deployed function, set these instead
# via `firebase functions:secrets:set DB_PASSWORD` (for the password) and
# `gcloud functions deploy app --set-env-vars INSTANCE_CONNECTION_NAME=...,DB_USER=...,DB_NAME=...`
# (or the equivalent Firebase/Google Cloud Console UI).
